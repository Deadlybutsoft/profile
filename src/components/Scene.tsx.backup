            borderRadius: '50%',
            animation: 'pulse-glow 10s ease-in-out infinite alternate'
          }} />
          <div style={{
            position: 'absolute',
            bottom: '20%',
            right: '20%',
            width: '400px',
            height: '400px',
            background: 'rgba(42, 27, 18, 0.05)',
            filter: 'blur(100px)',
            borderRadius: '50%',
            animation: 'pulse-glow 12s ease-in-out infinite alternate-reverse'
          }} />
          {/* Close Button - Hand Drawn Style */}
          <div
            onClick={(e) => {
              e.stopPropagation();
              setShowSkillsPopup(false);
              sfx.playClose();
            }}
            className="hand-drawn-close-btn"
            style={{
              position: 'absolute',
              top: '40px',
              right: '60px',
              width: '80px',
              height: '80px',
              display: 'flex', alignItems: 'center', justifyContent: 'center',
              cursor: 'pointer',
              zIndex: 10
            }}
          >
            <svg width="80" height="80" viewBox="0 0 100 100">
              <path
                d="M50 15c12-1 28 5 33 22 5 17-6 36-23 40-17 4-37-10-38-28-1-18 11-32 28-34"
                fill="none"
                stroke="#f6f1e6"
                strokeWidth="3.5"
                strokeLinecap="round"
                strokeLinejoin="round"
                opacity="1"
              />
              <path
                className="cross-line line-1"
                d="M35 37c8 6 22 19 30 26"
                fill="none"
                stroke="#f6f1e6"
                strokeWidth="3.5"
                strokeLinecap="round"
                opacity="0.8"
                style={{ transformOrigin: 'center', transition: 'transform 0.3s cubic-bezier(0.4, 0, 0.2, 1)' }}
              />
              <path
                className="cross-line line-2"
                d="M65 37c-7 8-23 20-30 26"
                fill="none"
                stroke="#f6f1e6"
                strokeWidth="3.5"
                strokeLinecap="round"
                opacity="0.8"
                style={{ transformOrigin: 'center', transition: 'transform 0.3s cubic-bezier(0.4, 0, 0.2, 1)' }}
              />
            </svg>
          </div>

          {/* Main Content Container */}
          <div style={{
            display: 'flex',
            flexDirection: 'column',
            alignItems: 'center',
            justifyContent: 'center',
            width: '100%',
            height: '100%',
            zIndex: 5,
          }}>

            {/* Title Section */}
            <div style={{
              textAlign: 'center',
              marginBottom: '30px',
              position: 'relative'
            }}>
              <div style={{ position: 'relative', display: 'inline-block' }}>
                <h1 style={{
                  margin: 0,
                  fontSize: '6rem',
                  fontFamily: '"Instrument Serif", serif',
                  fontWeight: '400',
                  color: '#f6f0e6',
                  lineHeight: '1.1',
                  letterSpacing: '-2px',
                  opacity: showSkillsPopup ? 1 : 0,
                  transform: showSkillsPopup ? 'translateY(0)' : 'translateY(30px)',
                  transition: 'all 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s',
                  whiteSpace: 'nowrap'
                }}>
                  My Skills
                </h1>

                {/* Refined Hand-drawn Underline specifically under 'Suvo' */}
                <svg
                  style={{ position: 'absolute', bottom: '-10px', left: '55%', width: '45%', height: '30px' }}
                  viewBox="0 0 150 30"
                >
                  {/* First Stroke */}
                  <path
                    d="M10 15c20-2 80-5 130 2"
                    fill="none"
                    stroke="#8b4513"
                    strokeWidth="3.5"
                    strokeLinecap="round"
                    style={{
                      strokeDasharray: 200,
                      strokeDashoffset: showSkillsPopup ? 0 : 200,
                      transition: 'stroke-dashoffset 1s ease 1.2s'
                    }}
                  />
                  {/* Second Scribble Stroke */}
                  <path
                    d="M15 22c30 1 70-2 120-1"
                    fill="none"
                    stroke="#8b4513"
                    strokeWidth="2"
                    strokeLinecap="round"
                    opacity="0.5"
                    style={{
                      strokeDasharray: 200,
                      strokeDashoffset: showSkillsPopup ? 0 : 200,
                      transition: 'stroke-dashoffset 1s ease 1.4s'
                    }}
                  />
                </svg>
              </div>

              {/* Profile Image - Sticker Mode */}
              <div style={{
                position: 'relative',
                width: '150px',
                height: '150px',
                flexShrink: 0,
                transform: showSkillsPopup ? 'rotate(-2deg) scale(1)' : 'rotate(-10deg) scale(0.8)',
                opacity: showSkillsPopup ? 1 : 0,
                transition: 'all 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 1s',
              }}>
                {/* Decorative Background Shadow/Border */}
                <div style={{
                  position: 'absolute',
                  top: '8px',
                  left: '8px',
                  width: '100%',
                  height: '100%',
                  backgroundColor: 'rgba(42, 27, 18, 0.08)',
                  borderRadius: '24px',
                  zIndex: 0
                }} />

                {/* Outer Brown Border */}
                <div style={{
                  position: 'absolute',
                  top: '4px',
                  left: '4px',
                  width: '100%',
                  height: '100%',
                  border: '2.5px solid #8b4513',
                  borderRadius: '24px',
                  zIndex: 1
                }} />

                {/* Main Sticker Container (White Cut-out) */}
                <div style={{
                  position: 'relative',
                  width: '100%',
                  height: '100%',
                  backgroundColor: '#ffffff',
                  padding: '7px',
                  borderRadius: '24px',
                  border: '2.5px solid #2a1b12',
                  zIndex: 2,
                  boxShadow: '0 8px 30px rgba(0,0,0,0.12)'
                }}>
                  {/* Image with rounded corners matching the sticker */}
                  <div style={{
                    width: '100%',
                    height: '100%',
                    borderRadius: '17px',
                    overflow: 'hidden',
                  }}>
                    <img
                      src="/profile_new.jpg"
                      alt="Suvo"
                      style={{
                        width: '100%',
                        height: '100%',
                        objectFit: 'cover'
                      }}
                    />
                  </div>
                </div>
              </div>
            </div>

            <div style={{
              marginTop: '40px',
              fontFamily: '"Bricolage Grotesque", sans-serif',
              fontSize: '1.4rem',
              lineHeight: '1.6',
              color: '#3e2723',
              fontWeight: '400',
              padding: '0 60px',
              maxWidth: '850px',
              letterSpacing: '0.01em',
              opacity: showSkillsPopup ? 1 : 0,
              transform: showSkillsPopup ? 'translateY(0)' : 'translateY(20px)',
              transition: 'all 0.8s ease 1.1s',
              textAlign: 'center'
            }}>
              A <strong style={{ color: '#8b4513', fontWeight: '600' }}>full-stack web developer</strong> focused on building scalable, efficient, and user-centric web applications. I work across both frontend and backend, translating product requirements into reliable, production-ready solutions.
            </div>

          </div>

          {/* Down Arrow Indicator */}
          <div style={{
            position: 'absolute',
            bottom: '50px',
            left: '50%',
            transform: 'translateX(-50%)',
            display: 'flex',
            flexDirection: 'column',
            alignItems: 'center',
            opacity: showSkillsPopup ? 0.7 : 0,
            transition: 'opacity 0.8s ease 1.5s',
            zIndex: 20
          }} className="animate-bounce">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#2a1b12" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
              <path d="M12 5v14M19 12l-7 7-7-7" />
            </svg>
          </div>
        </div>
      </div>

      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Gasoek+One&family=Bricolage+Grotesque:wght@200..800&family=Instrument+Serif:ital,wght@0,400;1,400&display=swap');

        @keyframes pulse {
          0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.7); }
          50% { transform: scale(1.05); box-shadow: 0 0 0 10px rgba(255, 255, 255, 0); }
          100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 255, 255, 0); }
        }

        @keyframes revealText {
          from { opacity: 0; transform: translateY(20px); }
          to { opacity: 1; transform: translateY(0); }
        }

        @keyframes remotePop {
          0% { opacity: 0; transform: translateY(100px) scale(0.5); }
          100% { opacity: 1; transform: translateY(0) scale(1); }
        }

        @keyframes pulse-glow {
          from { transform: scale(1) translate(0, 0); opacity: 0.1; }
          to { transform: scale(1.2) translate(20px, 20px); opacity: 0.2; }
        }

        .floating-icon {
          transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
          z-index: 10;
        }
        .floating-icon:hover {
          transform: translateY(-15px) scale(1.1) !important;
          z-index: 20;
        }
        .floating-icon:hover div {
           box-shadow: 0 30px 60px rgba(255, 255, 255, 0.1) !important;
           border-color: rgba(255, 255, 255, 0.5) !important;
        }

        .skill-card {
          cursor: pointer;
          transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .skill-card:hover {
          transform: translateY(-10px) scale(1.05);
        }
        .skill-card:hover div:first-child {
           box-shadow: 0 20px 40px rgba(42, 27, 18, 0.15) !important;
           border-color: #8b4513 !important;
        }

        .project-card {
           transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .project-card:hover {
          transform: translateY(-8px);
          box-shadow: 0 12px 40px rgba(42, 27, 18, 0.15) !important;
        }

        /* Floating Project Card Text Reveal */
        .project-text {
          font-family: "Instrument Serif", serif;
          font-size: 3rem;
          color: rgba(255, 255, 255, 0.7);
          text-transform: uppercase;
          letter-spacing: 0.15em;
          text-align: center;
          padding: 12px 0;
          opacity: 0;
          transform: translateY(-10px);
          transition: all 0.3s cubic-bezier(0.19, 1, 0.22, 1);
          display: flex;
          align-items: center;
          justify-content: center;
          gap: 6px;
        }

        .project-text h3 {
          font-family: "Instrument Serif", serif !important;
          font-size: 3rem !important;
          font-weight: 600 !important;
          font-style: normal !important;
          color: #f5f0e6 !important;
          margin: 0 0 12px 0 !important;
          letter-spacing: -1px !important;
          line-height: 0.9 !important;
          text-shadow: 0 0 30px rgba(0, 0, 0, 0.6);
        }

        .project-text p {
          font-family: "Bricolage Grotesque", sans-serif !important;
          font-size: 0.85rem !important;
          color: rgba(255, 255, 255, 0.6) !important;
          margin: 0 !important;
          line-height: 1.5 !important;
          font-weight: 400 !important;
          text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
          max-width: 220px;
        }

        .floating-project-card:hover .project-text {
          opacity: 1;
          transform: translateY(0);
          pointer-events: auto;
        }

        /* Click to View Text - Below Project Image */
        .click-to-view-text {
          font-family: "Bricolage Grotesque", sans-serif;
          font-size: 0.75rem;
          color: rgba(255, 255, 255, 0.7);
          text-transform: uppercase;
          letter-spacing: 0.15em;
          text-align: center;
          padding: 12px 0;
          opacity: 0;
          transform: translateY(-10px);
          transition: all 0.3s cubic-bezier(0.19, 1, 0.22, 1);
          display: flex;
          align-items: center;
          justify-content: center;
          gap: 6px;
        }

        .floating-project-card:hover .click-to-view-text {
          opacity: 1;
          transform: translateY(0);
        }

        /* Dimming Effect on Peer Hover */
        .floating-cards-container:hover .floating-project-card {
          opacity: 0.3 !important;
          filter: grayscale(100%);
          transform: scale(0.95);
        }

        .floating-cards-container .floating-project-card:hover {
          opacity: 1 !important;
          filter: grayscale(0%);
          z-index: 100;
        }

        /* Watermark Typography on Card Hover */
        .floating-cards-container:has(.floating-project-card:hover) .center-typography {
          opacity: 0.1 !important;
          transform: translate(-50%, -50%) scale(0.95) !important;
          filter: blur(0px);
        }

        /* GitHub Tooltip Effect Styles */
        :root {
          --bar-scale-y: 0;
          --sparkle-color: rgb(253 244 215 / 40%);
        }

        @keyframes pop-word {
          to { transform: rotateX(0); }
        }

        @keyframes show {
          to { opacity: 1; }
        }

        @keyframes bar-scale {
          to { transform: scaleY(1); }
        }

        @keyframes sparkle {
          0% { transform: scale(0); }
          60% { transform: scale(1) translate(4px, 1px) rotate(8deg); }
          100% { transform: scale(0) translate(4px, 1px) rotate(8deg); }
        }

        @keyframes shimmer {
          to { text-shadow: 0 0 8px rgba(239, 68, 68, 0.8); }
        }

        .github-tooltip h1 {
          color: white;
          font-family: "Gasoek One", sans-serif;
          font-size: 3.2rem;
          line-height: 1.2;
          perspective: 1000px;
          margin: 0;
          white-space: nowrap;
          pointer-events: none;
          display: flex;
          align-items: center;
          width: 600px; /* Increased width for capital letters */
          justify-content: center;
          text-transform: uppercase;
          letter-spacing: 2px;
        }

        .github-tooltip .word {
          display: inline-block;
          animation: show 1s forwards, pop-word 0.8s forwards;
          animation-timing-function: cubic-bezier(0.14, 1.23, 0.33, 1.16);
          opacity: 0;
          transform: rotateX(85deg);
          transform-origin: 50% 100%;
        }

        .github-tooltip .word:not(.superscript) {
          animation-delay: 0s;
        }

        .github-tooltip .superscript {
          margin-left: 1.2rem;
          animation-delay: 0.1s;
          color: #ffffff; /* Changed from Gold to White */
          position: relative;
          display: inline-block;
        }

        /* bars removed per user request */

        .github-tooltip.no-bars .superscript::before {
          display: none;
        }

        /* sparkle */
        .github-tooltip .superscript::after {
          --size: 3rem;
          position: absolute;
          top: -20%;
          left: -40%;
          width: var(--size);
          height: var(--size);
          animation: sparkle 0.4s linear 1.4s 1 forwards;
          background: radial-gradient(
              circle at center,
              rgb(252 249 241 / 94%) 0% 7%,
              transparent 7% 100%
            ),
            conic-gradient(
              transparent 0deg 18deg,
              var(--sparkle-color) 18deg,
              transparent 20deg 40deg,
              var(--sparkle-color) 40deg,
              transparent 43deg 87deg,
              var(--sparkle-color) 87deg,
              transparent 95deg 175deg,
              var(--sparkle-color) 175deg,
              transparent 178deg 220deg,
              var(--sparkle-color) 220deg,
              transparent 222deg 270deg,
              var(--sparkle-color) 270deg,
              transparent 275deg 300deg,
              var(--sparkle-color) 300deg,
              transparent 303deg 360deg
            );
          border-radius: 50%;
          clip-path: polygon(
            50% 0,
            59.13% 26.64%,
            85.13% -2.35%,
            100% 50%,
            50% 100%,
            0 50%,
            31.39% 34.86%
          );
          content: "";
          filter: blur(1px);
          transform: scale(0);
          position: absolute;
          top: -20%;
          left: -40%;
          width: var(--size);
          height: var(--size);
        }

        .hand-drawn-close-btn:hover .line-1,
        .hand-drawn-close-btn:hover .line-2 {
          transform: rotate(90deg);
        }

        @keyframes float {
          0%, 100% { transform: translateY(0px); }
          50% { transform: translateY(-20px); }
        }

        /* Paper Carousel Animations */
        .paper-skill-item:hover {
          transform: translateY(-5px) !important;
          box-shadow: 0 10px 20px rgba(139, 69, 19, 0.15) !important;
          background: rgba(255, 255, 255, 0.95) !important;
          border-color: rgba(139, 69, 19, 0.4) !important;
        }

        /* Dot Animations */
        /* Removed automatic carousel keyframes */
      `}</style>
    </div >
  );
};