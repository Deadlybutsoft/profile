          const cards = document.querySelectorAll('.floating-project-card');
          const centerX = window.innerWidth / 2;
          const centerY = window.innerHeight / 2;
          const mouseX = e.clientX;
          const mouseY = e.clientY;

          cards.forEach((card, index) => {
            const htmlCard = card as HTMLElement;
            const speed = -(0.35 + (index * 0.08));
            const offsetX = (mouseX - centerX) * speed;
            const offsetY = (mouseY - centerY) * speed;
            htmlCard.style.setProperty('--mouse-x', `${offsetX}px`);
            htmlCard.style.setProperty('--mouse-y', `${offsetY}px`);
          });
        }}
