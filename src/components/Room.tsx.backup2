                  <boxGeometry args={[0.04, 0.4, 0.03]} />
                  <meshStandardMaterial color="#000000" />
               </mesh>
            ))}

            {/* Armrests - Stealth Black */}
            {[-0.32, 0.32].map((x, i) => (
               <group key={i} position={[x, 0.7, 0.05]}>
                  {/* Armrest Vertical Support */}
                  <mesh position={[0, -0.1, 0]}>
                     <boxGeometry args={[0.02, 0.3, 0.02]} />
                     <meshStandardMaterial color="#000000" />
                  </mesh>
                  {/* Armrest Padding */}
                  <RoundedBox args={[0.1, 0.05, 0.35]} radius={0.02} smoothness={4} position={[0, 0.05, 0]}>
                     <meshStandardMaterial color="#000000" roughness={0.6} />
                  </RoundedBox>
               </group>
            ))}
         </group>
      </group>
   );
};
