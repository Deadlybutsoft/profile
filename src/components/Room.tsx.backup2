                  const t = performance.now() * 0.001;
                  // Sweeping motion for lasers
                  self.rotation.x = Math.sin(t * 0.7) * 0.5;
                  self.rotation.z = Math.cos(t * 0.5) * 0.3;
               }
            }}
         />



