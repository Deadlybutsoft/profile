import '@/lib/types';
import React, { useMemo, useRef } from 'react';
import * as THREE from 'three';
import { useFrame } from '@react-three/fiber';
import { Text, useTexture, RoundedBox, Billboard, Html, Edges, useCursor, useFBX, CubicBezierLine, Line } from '@react-three/drei';
import { useThree } from '@react-three/fiber';
import { sfx } from '@/lib/sfx';
import { smartDownload } from '@/lib/download';

const noop = () => {};

interface AnimatedSwitchButtonProps {
   onClick?: (e: any) => void;
   label?: string;
   onHoverChange?: (hovered: boolean) => void;
   disabled?: boolean;
   emphasis?: boolean;
}

const AnimatedSwitchButton: React.FC<AnimatedSwitchButtonProps> = ({ onClick, label, onHoverChange, disabled, emphasis = false }) => {
   const dotRef = useRef<THREE.Group>(null);
   const rippleRef = useRef<THREE.Mesh>(null);
   const [hovered, setHovered] = React.useState(false);

   useFrame((state) => {
      if (disabled) return;
      const t = state.clock.getElapsedTime();

      // Floating effect for the dot
      if (dotRef.current) {
         dotRef.current.position.z = 0.06 + Math.sin(t * 3) * 0.03;
         // Pulse size when hovered
         const scale = hovered ? 1.2 + Math.sin(t * 5) * 0.1 : 1;
         dotRef.current.scale.set(scale, scale, scale);
      }

      // Ripple effect
      if (rippleRef.current) {
         const s = (t * 0.8) % 1;
         rippleRef.current.scale.set(1 + s * 4, 1 + s * 4, 1);
         (rippleRef.current.material as THREE.MeshBasicMaterial).opacity = (1 - s) * (hovered ? 1 : 0.8);
      }
   });

   React.useEffect(() => {
      onHoverChange?.(hovered);
      if (hovered) {
         document.body.style.cursor = 'pointer';
         sfx.playHover();
      } else {
         document.body.style.cursor = 'auto';
      }
      return () => { document.body.style.cursor = 'auto'; };
   }, [hovered]);

   return (
      <group
         position={[0, 0, 0]}
         onClick={(e) => {
            if (disabled) return;
            e.stopPropagation();
            sfx.playClick();
            onClick?.(e);
         }}
         onPointerOver={() => !disabled && setHovered(true)}
         onPointerOut={() => setHovered(false)}
      >
         {/* Invisible Hit Area - Makes the entire circle interactive */}
         <mesh>
               <circleGeometry args={[emphasis ? 0.38 : 0.3, 32]} />
            <meshBasicMaterial transparent opacity={0} depthWrite={false} />
         </mesh>

         {/* Floating Dot */}
         <group ref={dotRef}>
            <mesh>
               <sphereGeometry args={[emphasis ? 0.052 : 0.04, 32, 32]} />
               <meshBasicMaterial color={hovered ? "#ffffff" : (emphasis ? "#f8ffff" : "#ffffff")} toneMapped={false} />
            </mesh>
         </group>

         {/* Ripple Wave */}
         <Billboard position={[0, 0, 0.08]}>
            <mesh ref={rippleRef}>
               <ringGeometry args={emphasis ? [0.06, 0.072, 32] : [0.047, 0.053, 32]} />
               <meshBasicMaterial
                  color={hovered ? "#ffffff" : (emphasis ? "#eaffff" : "#ffffff")}
                  transparent
                  opacity={emphasis ? 1 : 0.9}
                  toneMapped={false}
                  depthWrite={false}
                  side={THREE.DoubleSide}
                  polygonOffset
                  polygonOffsetFactor={-1}
               />
            </mesh>
         </Billboard>

         {/* Hover Tooltip Label */}
         {hovered && label && (
            <Html position={[0, 0.4, 0]} center distanceFactor={6}>
               <div className="github-tooltip no-bars">
                  <h1>
                     <span className="word">{label.split(' ')[0]}</span>
                     {label.split(' ')[1] && <span className="word superscript">{label.split(' ')[1]}</span>}
                  </h1>
               </div>
            </Html>
         )}
      </group>
   );
};

interface RoomProps {
   lightsOn: boolean;
   lightColor: string;
   lightIntensity: number;
   hexagonLightsOn: boolean;
   fanSpeed: number;
   roomMode: 'normal' | 'night' | 'party';
   showRemote: boolean;
   isDoorOpen: boolean;
   onToggleRemote: () => void;
   onToggleWardrobe: () => void;
   onToggleSkills: () => void;
   onToggleAI: () => void;
   isPopupOpen: boolean;
}

const Bulb: React.FC<{ position: THREE.Vector3, color: string, index: number }> = ({ position, color, index }) => {
   const meshRef = useRef<THREE.Mesh>(null);
   useFrame(({ clock }) => {
      if (meshRef.current) {
         const t = clock.getElapsedTime();
         // Twinkle effect
         const intensity = 1.0 + Math.sin(t * 3 + index * 1337) * 0.5;
         (meshRef.current.material as THREE.MeshStandardMaterial).emissiveIntensity = intensity;
      }
   });

   return (
      <mesh ref={meshRef} position={position}>
         <sphereGeometry args={[0.015, 8, 8]} />
         <meshStandardMaterial color={color} emissive={color} emissiveIntensity={1} toneMapped={false} />
      </mesh>
   );
};

const FairyLightStrand: React.FC<{ start: [number, number, number], mid: [number, number, number], end: [number, number, number] }> = ({ start, mid, end }) => {
   const colors = ['#ff0044', '#00ff44', '#3300ff', '#ffaa00', '#00ffff'];
   const curve = useMemo(() => {
      const c = new THREE.CatmullRomCurve3([
         new THREE.Vector3(...start),
         new THREE.Vector3(...mid),
         new THREE.Vector3(...end)
      ]);
      return c;
   }, [start, mid, end]);

   const points = useMemo(() => curve.getPoints(50), [curve]);
   const bulbPoints = useMemo(() => curve.getSpacedPoints(25), [curve]);

   return (
      <group>
         <Line points={points} color="#111" lineWidth={1} />
         {bulbPoints.map((pt, i) => (
            <Bulb key={i} position={pt} color={colors[i % colors.length]} index={i} />
         ))}
      </group>
   );
};

export const Room: React.FC<RoomProps> = ({
   lightsOn,
   lightColor,
   lightIntensity,
   hexagonLightsOn,
   fanSpeed,
   roomMode,
   showRemote,
   isDoorOpen,
   onToggleRemote = noop,
   onToggleWardrobe = noop,
   onToggleSkills = noop,
   onToggleAI = noop,
   isPopupOpen
}) => {
   const { camera } = useThree();
   const [monitorOn, setMonitorOn] = React.useState(true);
   const [tvOn, setTvOn] = React.useState(true);

   const fanRef = React.useRef<THREE.Group>(null);
   const currentFanRotationSpeed = React.useRef(0);
   const [partyColor, setPartyColor] = React.useState('#ff0000');
   const [inHallway, setInHallway] = React.useState(true);

   // Load Speaker Model
   const speakerFBX = useFBX('/big speaker.fbx');
   const speakerModel = useMemo(() => {
      const clone = speakerFBX.clone();
      clone.traverse((child) => {
         if ((child as THREE.Mesh).isMesh) {
            child.castShadow = true;
            child.receiveShadow = true;
         }
      });
      return clone;
   }, [speakerFBX]);


   const [posterHovered, setPosterHovered] = React.useState(false);
   const [monitorHovered, setMonitorHovered] = React.useState(false);
   const [switchboardHovered, setSwitchboardHovered] = React.useState(false);

   const [shelfHovered, setShelfHovered] = React.useState(false);
   const [linkedinHovered, setLinkedinHovered] = React.useState(false);
   const [xHovered, setXHovered] = React.useState(false);
   const [githubHovered, setGithubHovered] = React.useState(false);
   const [mailHovered, setMailHovered] = React.useState(false);
   const [cvHovered, setCvHovered] = React.useState(false);
   const [contraHovered, setContraHovered] = React.useState(false);
   const [wardrobeHovered, setWardrobeHovered] = React.useState(false);

   useFrame((state, delta) => {
      const t = state.clock.getElapsedTime();

      // Fan Logic
      if (fanRef.current) {
         const targetSpeed = fanSpeed * 2.5;
         currentFanRotationSpeed.current += (targetSpeed - currentFanRotationSpeed.current) * delta;
         fanRef.current.rotation.y += currentFanRotationSpeed.current * delta;
      }

      // Rainbow color cycle
      if (roomMode === 'party') {
         const h = (t * 0.5) % 1;
         const color = new THREE.Color().setHSL(h, 0.8, 0.5);
         setPartyColor('#' + color.getHexString());
      }

      // Update hallway visibility check
      const currentInHallway = camera.position.z > -4.1;
      if (currentInHallway !== inHallway) {
         setInHallway(currentInHallway);
      }
   });

   const currentLightColor = roomMode === 'party' ? partyColor : lightColor;
   const currentIntensity = roomMode === 'night' ? 0.1 : (roomMode === 'party' ? 6.0 : lightIntensity);

   const roomWidth = 8;
   const roomDepth = 6;
   const roomHeight = 3.2;
   const zOffset = -4 - (roomDepth / 2); // Center of the room (-8) -> Adjusted for depth

   // Laser refs for animation
   const laser1Ref = useRef<THREE.Group>(null);
   const laser2Ref = useRef<THREE.Group>(null);
   const laser3Ref = useRef<THREE.Group>(null);
   const laser4Ref = useRef<THREE.Group>(null);
   const laser5Ref = useRef<THREE.Group>(null);

   // Animate lasers in party mode
   useFrame((state) => {
      if (roomMode !== 'party') return;
      const t = state.clock.getElapsedTime();

      // Sweeping motion for each laser with different speeds and phases
      if (laser1Ref.current) {
         laser1Ref.current.rotation.x = Math.sin(t * 0.7) * 0.6;
         laser1Ref.current.rotation.z = Math.cos(t * 0.5) * 0.4;
      }
      if (laser2Ref.current) {
         laser2Ref.current.rotation.x = Math.sin(t * 0.9 + 1) * 0.5;
         laser2Ref.current.rotation.z = Math.cos(t * 0.6 + 1) * 0.5;
      }
      if (laser3Ref.current) {
         laser3Ref.current.rotation.x = Math.sin(t * 0.8 + 2) * 0.7;
         laser3Ref.current.rotation.z = Math.cos(t * 0.4 + 2) * 0.3;
      }
      if (laser4Ref.current) {
         laser4Ref.current.rotation.x = Math.sin(t * 0.6 + 3) * 0.4;
         laser4Ref.current.rotation.z = Math.cos(t * 0.7 + 3) * 0.6;
      }
      if (laser5Ref.current) {
         laser5Ref.current.rotation.x = Math.sin(t * 1.1 + 4) * 0.5;
         laser5Ref.current.rotation.z = Math.cos(t * 0.8 + 4) * 0.4;
      }
   });

   // Load textures
   const carpetTexture = useTexture('/final_carpet.jpg');
   // Set to 1,1 because we are now using 4 separate meshes for the 4 parts
   carpetTexture.repeat.set(1, 1);

   const wallTexture = useTexture('/grey_wall.jpg');
   wallTexture.repeat.set(1, 1);

   const ceilingTexture = useTexture('/ceiling_texture.jpg');
   ceilingTexture.repeat.set(1, 1);

   const windowTexture = useTexture('/window_view_new.png');
   windowTexture.anisotropy = 16;
   windowTexture.wrapS = windowTexture.wrapT = THREE.RepeatWrapping;
   windowTexture.colorSpace = THREE.SRGBColorSpace;

   const deskTexture = useTexture('/desk_wood.jpg');
   deskTexture.anisotropy = 16;
   deskTexture.colorSpace = THREE.SRGBColorSpace;

   const drawerTexture = useTexture('/drawer_texture.jpg');
   drawerTexture.anisotropy = 16;
   drawerTexture.colorSpace = THREE.SRGBColorSpace;

   const cabinetTexture = useTexture('/cabinet_wood.jpg');
   cabinetTexture.anisotropy = 16;
   cabinetTexture.colorSpace = THREE.SRGBColorSpace;

   const bedTexture = useTexture('/bed_texture_vibe.jpg');
   bedTexture.anisotropy = 16;
   bedTexture.wrapS = bedTexture.wrapT = THREE.RepeatWrapping;
   bedTexture.colorSpace = THREE.SRGBColorSpace;

   const bedBaseTexture = useTexture('/bed_base_wood.jpg');
   bedBaseTexture.anisotropy = 16;
   bedBaseTexture.wrapS = bedBaseTexture.wrapT = THREE.RepeatWrapping;
   bedBaseTexture.colorSpace = THREE.SRGBColorSpace;

   const wardrobeTexture = useTexture('/wardrobe_texture.jpg');
   wardrobeTexture.anisotropy = 16;
   wardrobeTexture.colorSpace = THREE.SRGBColorSpace;

   const shelfVerticalTexture = useTexture('/shelf_vertical_wood.jpg');
   shelfVerticalTexture.anisotropy = 16;
   shelfVerticalTexture.colorSpace = THREE.SRGBColorSpace;

   const pillowTexture = useTexture('/pillow_texture.jpg');
   pillowTexture.anisotropy = 16;
   pillowTexture.colorSpace = THREE.SRGBColorSpace;

   const shelfSlabTexture = useTexture('/shelf_slab_wood.jpg');
   shelfSlabTexture.anisotropy = 16;
   shelfSlabTexture.colorSpace = THREE.SRGBColorSpace;

   const chairTexture = useTexture('/chair_fabric.jpg');
   chairTexture.anisotropy = 16;
   chairTexture.colorSpace = THREE.SRGBColorSpace;
   chairTexture.wrapS = chairTexture.wrapT = THREE.RepeatWrapping;

   const keyboardTexture = useTexture('/custom_keyboard.jpg');
   keyboardTexture.colorSpace = THREE.SRGBColorSpace;

   const deskMatTexture = useTexture('/desk_mat_design.jpg');
   deskMatTexture.colorSpace = THREE.SRGBColorSpace;
   deskMatTexture.anisotropy = 16;

   const switchboardTexture = useTexture('/switchboard.png');
   switchboardTexture.colorSpace = THREE.SRGBColorSpace;

   const contributionTexture = useTexture('/contribution_graph_new.png');
   contributionTexture.colorSpace = THREE.SRGBColorSpace;

   const githubLogoTexture = useTexture('/github_logo.png');
   githubLogoTexture.colorSpace = THREE.SRGBColorSpace;

   const downloadIconTexture = useTexture('/download_icon.png');
   downloadIconTexture.colorSpace = THREE.SRGBColorSpace;

   const mailIconTexture = useTexture('/mail_icon.png');
   mailIconTexture.colorSpace = THREE.SRGBColorSpace;

   const monitorTexture = useTexture('/mac_screen.png');
   monitorTexture.colorSpace = THREE.SRGBColorSpace;
   monitorTexture.anisotropy = 16;

   const quoteTexture = useTexture('/motivational_quote_v2.png');
   quoteTexture.colorSpace = THREE.SRGBColorSpace;

   const appleLogoTexture = useTexture('/apple_logo.png');
   appleLogoTexture.colorSpace = THREE.SRGBColorSpace;

   const contraLogoTexture = useTexture('/contra_logo.png');
   contraLogoTexture.colorSpace = THREE.SRGBColorSpace;


   const skillsBgTexture = useTexture('/skills_bg_new.png');
   skillsBgTexture.anisotropy = 16;
   skillsBgTexture.colorSpace = THREE.SRGBColorSpace;

   const skillsBgBlackTexture = useTexture('/skills_bg_black.png');
   skillsBgBlackTexture.anisotropy = 16;
   skillsBgBlackTexture.colorSpace = THREE.SRGBColorSpace;

   const skillsBgNewTexture = useTexture('/skills_bg_new.png');
   skillsBgNewTexture.anisotropy = 16;
   skillsBgNewTexture.colorSpace = THREE.SRGBColorSpace;

   const skillsBgGrainyTexture = useTexture('/skills_bg_grainy.jpg');
   skillsBgGrainyTexture.anisotropy = 16;
   skillsBgGrainyTexture.colorSpace = THREE.SRGBColorSpace;


   // Doorway Logic (Front Wall) - Keeping existing door position
   const frontDoorWidth = 1.2;
   const frontDoorHeight = 3.2;
   const frontDoorPosX = -3.3;
   const fHoleLeft = frontDoorPosX - frontDoorWidth / 2;
   const fHoleRight = frontDoorPosX + frontDoorWidth / 2;

   // Generate Blinds for Window
   const blinds = useMemo(() => {
      return Array.from({ length: 12 }).map((_, i) => (
         <mesh key={i} position={[0, 1.0 - i * 0.18, 0.05]} castShadow receiveShadow>
            <boxGeometry args={[2.8, 0.14, 0.02]} />
            <meshStandardMaterial color="#f0f0f0" />
         </mesh>
      ));
   }, []);

   return (
      <group position={[0, 0, zOffset]}>
         {/* --- STRUCTURE --- */}

         {/* Diamond Pattern Plush Carpet Floor - 4 Parts */}
         <group rotation={[-Math.PI / 2, 0, 0]}>
            {/* Top Left */}
            <mesh position={[-roomWidth / 4, roomDepth / 4, 0]} receiveShadow>
               <planeGeometry args={[roomWidth / 2, roomDepth / 2]} />
               <meshStandardMaterial map={carpetTexture} roughness={1} metalness={0} />
            </mesh>
            {/* Top Right */}
            <mesh position={[roomWidth / 4, roomDepth / 4, 0]} receiveShadow>
               <planeGeometry args={[roomWidth / 2, roomDepth / 2]} />
               <meshStandardMaterial map={carpetTexture} roughness={1} metalness={0} />
            </mesh>
            {/* Bottom Left */}
            <mesh position={[-roomWidth / 4, -roomDepth / 4, 0]} receiveShadow>
               <planeGeometry args={[roomWidth / 2, roomDepth / 2]} />
               <meshStandardMaterial map={carpetTexture} roughness={1} metalness={0} />
            </mesh>
            {/* Bottom Right */}
            <mesh position={[roomWidth / 4, -roomDepth / 4, 0]} receiveShadow>
               <planeGeometry args={[roomWidth / 2, roomDepth / 2]} />
               <meshStandardMaterial map={carpetTexture} roughness={1} metalness={0} />
            </mesh>
         </group>

         {/* Ceiling */}
         <mesh rotation={[Math.PI / 2, 0, 0]} position={[0, roomHeight, 0]}>
            <planeGeometry args={[roomWidth, roomDepth]} />
            <meshStandardMaterial map={ceilingTexture} roughness={1} />
         </mesh>

         {/* Ceiling Corner Trim / Crown Molding (No Glow) */}
         <group position={[0, roomHeight - 0.05, 0]}>
            {/* Back Strip */}
            <mesh position={[0, 0, -roomDepth / 2 + 0.05]}>
               <boxGeometry args={[roomWidth, 0.1, 0.1]} />
               <meshStandardMaterial color="#ffffff" />
            </mesh>
            {/* Front Strip */}
            <mesh position={[0, 0, roomDepth / 2 - 0.05]}>
               <boxGeometry args={[roomWidth, 0.1, 0.1]} />
               <meshStandardMaterial color="#ffffff" />
            </mesh>
            {/* Left Strip */}
            <mesh position={[-roomWidth / 2 + 0.05, 0, 0]} rotation={[0, Math.PI / 2, 0]}>
               <boxGeometry args={[roomDepth, 0.1, 0.1]} />
               <meshStandardMaterial color="#ffffff" />
            </mesh>
            {/* Right Strip */}
            <mesh position={[roomWidth / 2 - 0.05, 0, 0]} rotation={[0, Math.PI / 2, 0]}>
               <boxGeometry args={[roomDepth, 0.1, 0.1]} />
               <meshStandardMaterial color="#ffffff" />
            </mesh>
         </group>

         {/* Floor Corner Trim / Baseboards */}
         <group position={[0, 0.05, 0]}>
            {/* Back Strip */}
            <mesh position={[0, 0, -roomDepth / 2 + 0.05]}>
               <boxGeometry args={[roomWidth, 0.1, 0.1]} />
               <meshStandardMaterial color="#ffffff" />
            </mesh>
            {/* Front Strip */}
            <mesh position={[0, 0, roomDepth / 2 - 0.05]}>
               <boxGeometry args={[roomWidth, 0.1, 0.1]} />
               <meshStandardMaterial color="#ffffff" />
            </mesh>
            {/* Left Strip */}
            <mesh position={[-roomWidth / 2 + 0.05, 0, 0]} rotation={[0, Math.PI / 2, 0]}>
               <boxGeometry args={[roomDepth, 0.1, 0.1]} />
               <meshStandardMaterial color="#ffffff" />
            </mesh>
            {/* Right Strip */}
            <mesh position={[roomWidth / 2 - 0.05, 0, 0]} rotation={[0, Math.PI / 2, 0]}>
               <boxGeometry args={[roomDepth, 0.1, 0.1]} />
               <meshStandardMaterial color="#ffffff" />
            </mesh>
         </group>

         {/* WALLS */}
         {/* Front Wall (Entrance) - Precisely constructed with cutouts for the door */}

         {/* Re-implementing Precise Front Wall Cutouts */}
         <mesh
            position={[(-roomWidth / 2 + fHoleLeft) / 2, roomHeight / 2, roomDepth / 2 + 0.01]}
            rotation={[0, Math.PI, 0]}
            receiveShadow
         >
            <planeGeometry args={[Math.max(0.001, fHoleLeft - (-roomWidth / 2)), roomHeight]} />
            <meshStandardMaterial map={wallTexture} roughness={0.7} />
         </mesh>
         <mesh
            position={[(fHoleRight + roomWidth / 2) / 2, roomHeight / 2, roomDepth / 2 + 0.01]}
            rotation={[0, Math.PI, 0]}
            receiveShadow
         >
            <planeGeometry args={[roomWidth / 2 - fHoleRight, roomHeight]} />
            <meshStandardMaterial map={wallTexture} roughness={0.7} />
         </mesh>
         <mesh
            position={[frontDoorPosX, (roomHeight + frontDoorHeight) / 2, roomDepth / 2 + 0.01]}
            rotation={[0, Math.PI, 0]}
            receiveShadow
         >
            <planeGeometry args={[frontDoorWidth, roomHeight - frontDoorHeight]} />
            <meshStandardMaterial map={wallTexture} roughness={0.7} />
         </mesh>



         {/* Smart Switchboard (Window Wall - Near Door Corner) */}
         <group position={[-roomWidth / 2 + 0.02, 1.2, 1.5]} rotation={[0, Math.PI / 2, 0]}>
            {/* Mounting Plate */}
            <mesh castShadow>
               <boxGeometry args={[0.2, 0.3, 0.02]} />
               <meshStandardMaterial color="#222222" roughness={0.5} />
            </mesh>
            {/* Switchboard Face with Texture */}
            <mesh position={[0, 0, 0.011]}>
               <planeGeometry args={[0.18, 0.28]} />
               <meshBasicMaterial map={switchboardTexture} transparent={true} />
            </mesh>

            {/* Floating Animated Button Indicator (Pushed out to avoid wall clipping) */}
            <group position={[0, 0.21, 0.2]}>
               <AnimatedSwitchButton
                  disabled={!isDoorOpen}
                  onClick={onToggleRemote}
                  onHoverChange={(h) => {
                     setSwitchboardHovered(h);
                     // Auto-open remote on hover ONLY if door is open and not already showing
                     if (h && isDoorOpen && !showRemote) {
                        onToggleRemote();
                     }
                  }}
               />
            </group>
         </group>

         {/* Local Room Lighting - Toggled by Switchboard */}
         <pointLight
            position={[0, roomHeight - 0.5, 0]}
            intensity={lightsOn ? currentIntensity : 0}
            distance={15}
            color={currentLightColor}
            castShadow
         />






         {/* Back Wall */}
         <mesh position={[0, roomHeight / 2, -roomDepth / 2]} receiveShadow>
            <planeGeometry args={[roomWidth, roomHeight]} />
            <meshStandardMaterial map={wallTexture} roughness={0.7} />
         </mesh>



         {/* GitHub Contribution Poster (Back Wall - Wall 2) - Refined Size with Shadow */}
         <group position={[0, 1.8, -roomDepth / 2 + 0.04]} rotation={[0, 0, 0]}>
            {/* TUBE LIGHT above poster */}
            <group position={[0, 0.9, 0.05]}>
               {/* Tube Light Housing / Fixture */}
               <mesh position={[0, 0, -0.02]} castShadow>
                  <boxGeometry args={[2.2, 0.08, 0.06]} />
                  <meshStandardMaterial color="#333333" roughness={0.4} metalness={0.6} />
               </mesh>
               {/* Tube Light - Glowing White (rotated horizontally) - Only glows in normal mode */}
               <mesh position={[0, -0.02, 0]} rotation={[0, 0, Math.PI / 2]}>
                  <cylinderGeometry args={[0.025, 0.025, 2.0, 16]} />
                  <meshBasicMaterial
                     color={roomMode === 'normal' ? "#ffffff" : "#444444"}
                     toneMapped={false}
                  />
               </mesh>
               {/* Tube Light Glow Effect - Only visible in normal mode */}
               {roomMode === 'normal' && (
                  <mesh position={[0, -0.02, 0]} rotation={[0, 0, Math.PI / 2]}>
                     <cylinderGeometry args={[0.04, 0.04, 2.0, 16]} />
                     <meshBasicMaterial color="#ffffff" transparent opacity={0.3} toneMapped={false} />
                  </mesh>
               )}

               {/* Linear Light Distribution - Only active in normal mode */}
               {roomMode === 'normal' && (
                  <>
                     {/* Main Glow - RectAreaLight for linear soft light */}
                     <rectAreaLight
                        width={2.0}
                        height={0.1}
                        intensity={5}
                        color="#ffffff"
                        position={[0, -0.1, 0]}
                        rotation={[-Math.PI / 2, 0, 0]}
                     />
                     {/* 3 Point Lights evenly spaced to flush the wall properly */}
                     <pointLight position={[-0.8, -0.2, 0.2]} intensity={0.4} distance={3} color="#ffffff" decay={2} />
                     <pointLight position={[0, -0.2, 0.2]} intensity={0.4} distance={3} color="#ffffff" decay={2} />
                     <pointLight position={[0.8, -0.2, 0.2]} intensity={0.4} distance={3} color="#ffffff" decay={2} />
                  </>
               )}
               {/* End Caps */}
               <mesh position={[-1.0, -0.02, 0]} rotation={[0, 0, Math.PI / 2]}>
                  <cylinderGeometry args={[0.03, 0.03, 0.04, 16]} />
                  <meshStandardMaterial color="#888888" metalness={0.7} roughness={0.3} />
               </mesh>
               <mesh position={[1.0, -0.02, 0]} rotation={[0, 0, Math.PI / 2]}>
                  <cylinderGeometry args={[0.03, 0.03, 0.04, 16]} />
                  <meshStandardMaterial color="#888888" metalness={0.7} roughness={0.3} />
               </mesh>
            </group>

            {/* Soft Contact Shadow (Fake Shadow Plane) */}
            <mesh position={[0.02, -0.02, -0.015]}>
               <planeGeometry args={[2.9, 1.2]} />
